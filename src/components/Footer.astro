---
import { MapPin, Mail, Phone } from '@lucide/astro';
import Logo from './Logo.astro';
import { contact } from '../data/contact';
import { projects } from '../data/projects';

const year = new Date().getFullYear();
---

<footer id="oficina" class="bg-secondary text-white">
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-8 md:py-24">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">
      <div>
        <Logo class="h-12 w-auto" inverted />
        <p class="mt-4 font-body text-sm text-white/75">Invierte seguro con Expande Inmobiliaria.</p>
        <div class="mt-6 flex gap-3">
          <a
            href={contact.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook de Expande Inmobiliaria"
            class="flex size-9 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-primary"
          >
            <svg viewBox="0 0 24 24" class="size-4 fill-current"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.9h2.54V9.85c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33V22c4.78-.8 8.44-4.95 8.44-9.94Z"/></svg>
          </a>
          <a
            href={contact.social.tiktok}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TikTok de Expande Inmobiliaria"
            class="flex size-9 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-primary"
          >
            <svg viewBox="0 0 24 24" class="size-4 fill-current"><path d="M16.6 5.82c-.9-.98-1.4-2.26-1.4-3.6h-3.15v13.44a2.6 2.6 0 1 1-2.6-2.6c.24 0 .48.03.7.1V9.98a5.75 5.75 0 0 0-.7-.04A5.76 5.76 0 1 0 15.2 15.7V9.4a7.5 7.5 0 0 0 4.4 1.4V7.65c-1.06 0-2.06-.34-2.9-.9a5.9 5.9 0 0 1-.1-.93Z"/></svg>
          </a>
          <a
            href={contact.social.youtube}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube de Expande Inmobiliaria"
            class="flex size-9 items-center justify-center rounded-full bg-white/10 transition-colors hover:bg-primary"
          >
            <svg viewBox="0 0 24 24" class="size-4 fill-current"><path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.54 3.5 12 3.5 12 3.5s-7.54 0-9.38.55A3.02 3.02 0 0 0 .5 6.19C0 8.04 0 12 0 12s0 3.96.5 5.81a3.02 3.02 0 0 0 2.12 2.14C4.46 20.5 12 20.5 12 20.5s7.54 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14C24 15.96 24 12 24 12s0-3.96-.5-5.81ZM9.75 15.52V8.48L15.5 12l-5.75 3.52Z"/></svg>
          </a>
        </div>
      </div>

      <nav>
        <h3 class="font-heading text-sm font-medium uppercase tracking-wide text-white/50">Proyectos</h3>
        <ul class="mt-4 flex flex-col gap-3">
          {projects.map((project) => (
            <li>
              <a href="#proyectos" class="font-body text-sm text-white/75 hover:text-white">{project.name}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div>
        <h3 class="font-heading text-sm font-medium uppercase tracking-wide text-white/50">Oficina de ventas</h3>
        <ul class="mt-4 flex flex-col gap-3 font-body text-sm text-white/75">
          <li class="flex items-start gap-2">
            <MapPin class="size-4 flex-none translate-y-0.5 text-primary" />
            <span>{contact.office.address}</span>
          </li>
          <li>
            <a href={contact.office.mapUrl} target="_blank" rel="noopener noreferrer" class="link link-primary">
              Ver en Google Maps
            </a>
          </li>
          <li class="flex items-center gap-2">
            <Phone class="size-4 flex-none text-primary" />
            <a href={contact.phoneDirect.url} class="hover:text-white">{contact.phoneDirect.label}</a>
          </li>
          <li class="flex items-center gap-2">
            <Mail class="size-4 flex-none text-primary" />
            <a href={`mailto:${contact.email}`} class="hover:text-white">{contact.email}</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-heading text-sm font-medium uppercase tracking-wide text-white/50">Horario de atención</h3>
        <ul class="mt-4 flex flex-col gap-3 font-body text-sm text-white/75">
          {contact.hours.map((hour) => (
            <li class="flex justify-between gap-4">
              <span>{hour.label}</span>
              <span class="text-right text-white/50">{hour.value}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 font-body text-xs text-white/50 md:flex-row">
      <p>© {year} Expande Inmobiliaria. Todos los derechos reservados.</p>
      <p>Asistente Camila: {contact.whatsappCamila.label}</p>
    </div>
  </div>
</footer>
