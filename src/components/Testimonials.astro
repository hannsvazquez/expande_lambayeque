---
import TestimonialCard from './TestimonialCard.astro';
import { testimonials } from '../data/testimonials';

const images = import.meta.glob<{ default: ImageMetadata }>('../../Photos_Expande/*.{jpg,jpeg,png,webp,JPG,JPEG}', {
  eager: true,
});
const imageMap = Object.fromEntries(
  Object.entries(images).map(([path, mod]) => [path.split('/').pop() as string, mod.default])
);
---

<section class="bg-base-100 py-16 md:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="mb-12 flex flex-col gap-4 md:mb-16 md:max-w-2xl">
      <span class="badge badge-outline badge-primary w-fit font-body text-xs uppercase tracking-wide">Testimonios</span>
      <h2 class="font-heading text-3xl font-semibold text-secondary md:text-4xl">
        Invierte seguro con Expande Inmobiliaria
      </h2>
      <p class="font-body text-base text-base-content/75 md:text-lg">
        Más de 100 familias ya invirtieron en su futuro con nosotros. Estas son algunas de sus experiencias.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-3 md:gap-8">
      {testimonials.map((testimonial) => (
        <TestimonialCard testimonial={testimonial} image={testimonial.image ? imageMap[testimonial.image] : null} />
      ))}
    </div>
  </div>
</section>
