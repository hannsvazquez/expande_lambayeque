---
import { Play } from '@lucide/astro';
import { contact } from '../data/contact';

const videoId = 'zpPAOy5R89c';
const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
---

<section class="bg-secondary py-16 md:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="mb-12 flex flex-col gap-4 md:mb-16 md:max-w-2xl">
      <span class="badge badge-warning w-fit font-body text-xs uppercase tracking-wide">Recorrido 3D</span>
      <h2 class="font-heading text-3xl font-semibold text-white md:text-4xl">
        Vive el proyecto antes de construir tu futuro
      </h2>
      <p class="font-body text-base text-white/75 md:text-lg">
        Explora un recorrido en 3D de Expande de Lambayeque II y descubre la distribución de lotes, calles y áreas del proyecto.
      </p>
    </div>

    <div id="video3d-wrapper" class="relative aspect-video w-full overflow-hidden rounded-box border border-white/10">
      <button
        type="button"
        id="video3d-trigger"
        class="group absolute inset-0 block h-full w-full"
        aria-label="Reproducir video del recorrido 3D"
        data-video-id={videoId}
      >
        <img
          src={thumbnailUrl}
          alt="Render 3D — Expande de Lambayeque II"
          class="h-full w-full object-cover"
          loading="lazy"
        />
        <span class="absolute inset-0 bg-secondary/40 transition-colors group-hover:bg-secondary/20"></span>
        <span class="absolute inset-0 flex items-center justify-center">
          <span class="flex size-16 items-center justify-center rounded-full bg-primary text-white shadow-lg transition-transform group-hover:scale-110 md:size-20">
            <Play class="size-7 md:size-9" fill="currentColor" />
          </span>
        </span>
        <span class="absolute bottom-4 left-4 badge badge-outline border-white/40 font-body text-xs text-white">
          Render 3D · Expande de Lambayeque II
        </span>
      </button>
    </div>

    <p class="mt-10 font-body text-sm text-white/75">
      ¿Prefieres una visita guiada en vivo?
      <a href={contact.whatsappCamila.url} target="_blank" rel="noopener noreferrer" class="link link-warning font-medium mt-2 block">
        Coordina con Camila
      </a>
    </p>
  </div>
</section>

<script>
  const wrapper = document.getElementById('video3d-wrapper');
  const trigger = document.getElementById('video3d-trigger') as HTMLButtonElement | null;

  trigger?.addEventListener('click', () => {
    const videoId = trigger.dataset.videoId;
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`;
    iframe.title = 'Render 3D — Expande de Lambayeque II';
    iframe.className = 'absolute inset-0 h-full w-full';
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
    iframe.allowFullscreen = true;
    wrapper?.replaceChildren(iframe);
  });
</script>
