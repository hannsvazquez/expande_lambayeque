---
import { Image } from 'astro:assets';
import { House, ShieldCheck, UserCheck, Award } from '@lucide/astro';
import aboutImage from '../../Photos_Expande/testimonio-de-clientes.jpeg';

const features = [
  { icon: House, label: 'Casa propia', text: 'Lotes para construir el hogar que siempre soñaste.' },
  { icon: ShieldCheck, label: 'Inversión segura', text: 'Proyectos registrados en SUNARP, con gran potencial de revalorización.' },
  { icon: UserCheck, label: 'Asesoría personalizada', text: 'Te acompañamos en cada paso de tu inversión.' },
  { icon: Award, label: '+10 años en el mercado', text: 'Desde 2015 desarrollando proyectos con confianza y trayectoria.' },
];
---

<section id="nosotros" class="bg-base-100 py-16 md:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,3fr)_minmax(0,2fr)] lg:items-center lg:gap-16">
      <div class="relative overflow-hidden rounded-box">
        <Image src={aboutImage} alt="Familia con lote propio de Expande Inmobiliaria" width={900} height={700} class="h-full w-full object-cover" />
        <div class="absolute bottom-4 left-4 rounded-box bg-base-100/95 px-4 py-3 shadow-lg">
          <span class="font-heading text-2xl font-semibold text-secondary">+100</span>
          <span class="block font-body text-xs text-base-content/75">familias con lote propio</span>
        </div>
      </div>

      <div>
        <span class="badge badge-outline badge-primary mb-4 font-body text-xs uppercase tracking-wide">Sobre nosotros</span>
        <h2 class="mb-6 font-heading text-3xl font-semibold text-secondary md:text-4xl">
          Más de 10 años acompañando a familias e inversionistas
        </h2>
        <p class="font-body text-base text-base-content/75 md:text-lg">
          Somos una inmobiliaria del norte del país especializada en el desarrollo de proyectos de lotización para expansión urbana.
          Acompañamos a las familias que buscan construir su casa propia y a los inversionistas que buscan nuevas oportunidades de
          rentabilidad, con el respaldo legal y documentario que necesita cada inversión en la región Lambayeque.
        </p>

        <div class="mt-8 grid grid-cols-2 border border-base-300">
          <div class="flex flex-col items-center gap-1 text-center border-r border-b border-base-300 px-3 py-4">
            <span class="font-heading text-sm font-semibold text-secondary sm:text-lg">Financiamiento directo</span>
            <span class="font-body text-xs text-base-content/75">0% interés</span>
          </div>
          <div class="flex flex-col items-center gap-1 text-center border-b border-base-300 px-3 py-4">
            <span class="font-heading text-sm font-semibold text-secondary sm:text-lg">Partidas registrales</span>
            <span class="font-body text-xs text-base-content/75">SUNARP</span>
          </div>
          <div class="col-span-2 flex flex-col items-center gap-1 text-center px-3 py-4">
            <span class="font-heading text-sm font-semibold text-secondary sm:text-lg">Lotes de hasta</span>
            <span class="font-body text-xs text-base-content/75">359 m²</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16 grid grid-cols-2 gap-6 md:mt-24 md:grid-cols-4 md:gap-8">
      {features.map((feature) => (
        <div class="flex flex-col items-start gap-3">
          <span class="flex size-11 items-center justify-center rounded-full bg-primary/10 text-primary">
            <feature.icon class="size-5" />
          </span>
          <h3 class="font-heading text-base font-medium text-secondary">{feature.label}</h3>
          <p class="font-body text-sm text-base-content/75">{feature.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
