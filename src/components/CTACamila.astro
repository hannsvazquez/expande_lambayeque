---
import { Image } from 'astro:assets';
import { MessageCircle, Zap } from '@lucide/astro';
import { contact } from '../data/contact';
import phoneMockup from '../../Photos_Expande/Mockuuups-iPhone-17.png';
---

<section id="camila" class="bg-secondary py-16 md:py-24 lg:py-32">
  <div class="mx-auto grid max-w-7xl items-center gap-12 px-6 md:px-8 lg:grid-cols-2 lg:gap-16">
    <div>
      <span class="badge badge-warning mb-4 font-body text-xs uppercase tracking-wide">Asistente virtual 24/7</span>
      <h2 class="mb-6 font-heading text-3xl font-semibold text-white md:text-4xl">
        Camila resuelve tus dudas al instante
      </h2>
      <p class="mb-8 font-body text-base text-white/75 md:text-lg">
        Nuestra asistente virtual te acompaña en todo momento: precios, disponibilidad de lotes, formas de pago,
        información legal y recomendaciones personalizadas. Escríbele por WhatsApp y recibe respuesta inmediata,
        cualquier día y a cualquier hora.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        <a href={contact.whatsappCamila.url} target="_blank" rel="noopener noreferrer" class="btn btn-success text-white">
          <MessageCircle class="size-5" />
          Conversar por WhatsApp
        </a>
        <span class="flex items-center gap-1.5 font-body text-sm text-white/75">
          <Zap class="size-4 text-warning" />
          Respuesta inmediata
        </span>
      </div>
    </div>

    <div class="mx-auto max-w-xs md:max-w-sm">
      <Image
        src={phoneMockup}
        alt="Conversación con Camila, asistente virtual de Expande Inmobiliaria"
        class="w-full h-auto drop-shadow-2xl"
        loading="lazy"
      />
    </div>
  </div>
</section>
