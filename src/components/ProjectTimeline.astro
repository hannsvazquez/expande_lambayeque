---
import { Image } from 'astro:assets';
import { MapPin } from '@lucide/astro';
import { projects, type ProjectStatus } from '../data/projects';

const images = import.meta.glob<{ default: ImageMetadata }>('../../Photos_Expande/*.{jpg,jpeg,png,webp,JPG,JPEG}', {
  eager: true,
});
const imageMap = Object.fromEntries(
  Object.entries(images).map(([path, mod]) => [path.split('/').pop() as string, mod.default])
);

const statusBadgeClass: Record<ProjectStatus, string> = {
  completado: 'badge-outline',
  'en-venta': 'badge-primary',
  'nuevo-lanzamiento': 'badge-warning',
};
---

<section id="proyectos" class="bg-base-200 py-16 md:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="mb-12 flex flex-col gap-4 md:mb-16 md:max-w-2xl">
      <span class="badge badge-outline badge-primary w-fit font-body text-xs uppercase tracking-wide">Nuestros proyectos</span>
      <h2 class="font-heading text-3xl font-semibold text-secondary md:text-4xl">
        Proyectos de lotes en Lambayeque y Chiclayo
      </h2>
      <p class="font-body text-base text-base-content/75 md:text-lg">
        Desde 2015, hemos desarrollado proyectos de lotización en zonas estratégicas de Lambayeque y Chiclayo.
      </p>
    </div>

    <ol class="relative border-l border-base-300 pl-8 md:pl-10">
      {projects.map((project) => (
        <li class="mb-12 last:mb-0">
          <span class="absolute -left-[7px] mt-1.5 size-3.5 rounded-full border-2 border-base-200 bg-primary"></span>
          <div class="flex flex-col gap-6 rounded-box bg-base-100 p-6 shadow-sm md:flex-row md:items-center md:gap-8 md:p-8">
            <Image
              src={imageMap[project.image]}
              alt={project.name}
              width={320}
              height={220}
              class="h-40 w-full rounded-box object-cover md:h-32 md:w-48 md:flex-none"
            />
            <div class="flex-1">
              <div class="mb-2 flex flex-wrap items-center gap-3">
                <span class="font-body text-xs font-medium uppercase tracking-wide text-base-content/50">{project.year}</span>
                <span class={`badge ${statusBadgeClass[project.status]} font-body text-xs`}>{project.statusLabel}</span>
              </div>
              <h3 class="font-heading text-xl font-medium text-secondary">{project.name}</h3>
              <p class="mt-1 flex items-center gap-1.5 font-body text-sm text-base-content/75">
                <MapPin class="size-4 flex-none text-primary" />
                {project.location}
              </p>
              <p class="mt-2 font-body text-sm text-base-content/75">{project.description}</p>
              {project.mapUrl && (
                <a
                  href={project.mapUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-outline btn-primary btn-sm mt-4"
                >
                  Ver en Google Maps
                </a>
              )}
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
