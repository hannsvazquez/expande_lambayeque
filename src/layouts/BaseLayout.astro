---
import '../styles/global.css';
import { contact } from '../data/contact';
import logo from '../../Photos_Expande/Logo-Expande-Lambayeque.png';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Expande Inmobiliaria | Venta de Lotes en Lambayeque y Chiclayo',
  description = 'Más de 10 años de experiencia en venta de lotes en Lambayeque y Chiclayo. Proyectos de lotización registrados en SUNARP, ideales para tu casa propia o como inversión.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: 'Expande Inmobiliaria',
  image: new URL(logo.src, Astro.site).toString(),
  url: Astro.site?.toString(),
  telephone: contact.phoneDirect.number,
  email: contact.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: contact.office.address,
    addressLocality: 'Chiclayo',
    addressRegion: 'Lambayeque',
    addressCountry: 'PE',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Saturday'],
      opens: '09:00',
      closes: '13:00',
    },
  ],
  sameAs: [contact.social.facebook, contact.social.tiktok],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/Site-icon-Expande.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icons/icon-512.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Venta de lotes en Lambayeque, Inmobiliarias en Lambayeque, Inmobiliarias en Chiclayo, Lotes para inversión, Lotes para casa propia, Proyecto de lotes, Terrenos en venta"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(logo.src, Astro.site).toString()} />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content="Expande Inmobiliaria" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(logo.src, Astro.site).toString()} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body class="bg-base-100 text-base-content">
    <slot />
  </body>
</html>
